{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Language Learning Library",
  "version": "0.1.0",
  "identifier": "com.kdawg.languagelearninglibrary",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Language Learning Library",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; media-src 'self' asset: http://asset.localhost file:; img-src 'self' asset: http://asset.localhost; frame-src 'self' asset: http://asset.localhost file:;",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
